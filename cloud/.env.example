# Gerar com: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME

PHX_HOST=vigipro.mahina.cloud

# JWK JSON da chave EC do Supabase (Settings → API → JWT Settings → copiar JWK)
# Se definido, usa ES256 (modo moderno). Deixar vazio para fallback HS256.
SUPABASE_JWK={"x":"...","y":"...","alg":"ES256","crv":"P-256","kty":"EC","kid":"..."}

# Fallback legado HS256 (só se SUPABASE_JWK não for usado)
SUPABASE_JWT_SECRET=CHANGE_ME

# String aleatória longa — openssl rand -hex 32
EPHEMERAL_TOKEN_SECRET=CHANGE_ME
